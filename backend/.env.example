# CDP credentials — create at https://portal.cdp.coinbase.com
# API key (Settings -> API keys):
CDP_API_KEY_ID=your-api-key-id
CDP_API_KEY_SECRET=your-api-key-secret
# Wallet Secret (Server Wallets -> Wallet Secret):
CDP_WALLET_SECRET=your-wallet-secret

# Local search (both are required to enable the live POST /query path)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cacheapp
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SEARCH_MATCH_THRESHOLD=0.75
SEARCH_SESSION_CANDIDATE_COUNT=5
SEARCH_PREVIEW_COUNT=3
